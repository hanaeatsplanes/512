---
import Index from "@/pages/index.astro"
import { Image } from "astro:assets"
import orpheusFlag from "@/assets/flag-orpheus-left.svg"
---


<div id="container" class="h-screen w-screen">
    <a href="https://hackclub.com" class="absolute">
        <Image src={orpheusFlag}
             alt="Hack Club Flag"
             style={`width: clamp(100px, 15vw, 300px);`}
        />
    </a>
    <div id="textContainer" class="h-screen w-screen my-auto flex flex-col items-center justify-center text-center px-4">
        <h1 class="title">512</h1>
        <h2 class="text-5xl">You ship a tiny site,</h2>
        <h2 class="text-5xl">We get you into a site hall of fame.</h2>
        <p class="text-2xl">(also some stickers :D)</p>
        <a href="https://www.youtube.com/watch?v=dQw4w9WgXcQ">
            <button>Submit</button>
        </a>
    </div>
</div>

<style>
    .title {
        font-family: 'Jacquard 12', serif;
        color: white;
        font-size: 12vw;
        padding: 0;
        margin: 0;
        line-height: 1;
    }
    button {
        border: white solid 1px;
        margin: 1rem;
        padding: 0.5rem 2rem;
        font-size: 3vw;
        background: #ec3750;
        color: white;
        cursor: pointer;
        transition: background 0.2s;
    }
    button:hover {
        background: #c7283e;
    }
</style>
